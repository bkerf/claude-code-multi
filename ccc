#!/usr/bin/env bash
set -euo pipefail

# Claude Code Commander (ccc)
# Repo-local launcher: switch model via ccm.sh and then exec `claude`
# This affects only the spawned `claude` process, not your parent shell.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
CCM_CMD_DEFAULT="$SCRIPT_DIR/ccm.sh"
CCM="${CCM_CMD:-$CCM_CMD_DEFAULT}"

usage() {
    cat <<EOF
Usage: ./ccc <provider>[:<model>] [region] [claude-options]
       ./ccc open <provider> [claude-options]
       ./ccc <account> [claude-options]        # Switch account then launch (default model)
       ./ccc <model>:<account> [claude-options]

Alibaba Cloud Coding Plan (ali):
  ali[:qwen|kimi|glm|minimax] [china|global]   - 4 models available
    qwen    - qwen3.5-plus (multimodal)
    kimi    - kimi-k2.5 (multimodal)
    glm     - glm-5
    minimax - MiniMax-M2.5

Other providers:
  deepseek|ds              - DeepSeek
  kimi [china|global]      - Kimi (Moonshot, direct)
  glm [china|global]       - GLM (Zhipu, direct)
  minimax [china|global]   - MiniMax (direct)
  seed|doubao [variant]    - Seed/ARK
  stepfun                  - StepFun
  claude|sonnet|s          - Claude (official)

Examples:
  ./ccc ali                         # Default: qwen3.5-plus, china region
  ./ccc ali:qwen                    # qwen3.5-plus, china region
  ./ccc ali:kimi:global             # kimi-k2.5, global region
  ./ccc ali:glm china               # glm-5, china region
  ./ccc kimi global                 # Kimi direct (Moonshot API)
  ./ccc woohelps                    # Switch to 'woohelps' account
  CCM_SKIP_PERMISSIONS=0 ./ccc kimi # Disable auto skip permissions

Note: --dangerously-skip-permissions is added by default.
      Set CCM_SKIP_PERMISSIONS=0 to disable.
EOF
}

if [[ ! -f "$CCM" ]]; then
    echo "ccc error: cannot find ccm CLI at $CCM" >&2
    echo "Hint: ensure ccm.sh exists next to this script, or set CCM_CMD=/path/to/ccm.sh" >&2
    exit 1
fi

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

# 帮助信息
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    usage
    exit 0
fi

model=""
open_provider=""
region_arg=""
seed_variant=""
model_variant=""

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

if [[ "${1:-}" == "open" ]]; then
    shift || true
    if [[ $# -lt 1 ]]; then
        usage
        exit 1
    fi
    model="open"
    open_provider="$1"
    shift || true
else
    model="$1"
    shift || true
fi

# Helper: is known model keyword
is_known_model() {
    local check_model="$1"
    # 去除可能的 :variant 后缀
    check_model="${check_model%%:*}"
    case "$check_model" in
        deepseek|ds|glm|glm4|glm4.6|glm4.7|kimi|kimi2|ali|alibaba|minimax|mm|seed|doubao|claude|sonnet|s|open|stepfun)
            return 0 ;;
        *)
            return 1 ;;
    esac
}

# 解析 provider:variant 格式（冒号分隔语法）
# 支持格式: qwen:plus, qwen:plus:china, qwen:plus china
if [[ "$model" != "open" ]] && [[ "$model" == *:* ]] && is_known_model "$model"; then
    model_variant="${model#*:}"
    model="${model%%:*}"

    # 检查 variant 本身是否还包含冒号 (qwen:plus:china 格式)
    if [[ "$model_variant" == *:* ]]; then
        embedded_region="${model_variant#*:}"
        model_variant="${model_variant%%:*}"
        # 如果嵌入的区域是有效区域，设置为 region_arg
        if [[ "$embedded_region" =~ ^(global|china|cn)$ ]]; then
            region_arg="$embedded_region"
        fi
    fi
fi

# Account-only mode: `ccc <account>` (not open, not known model, no colon, no variant)
if [[ "$model" != "open" ]] && [[ -z "$model_variant" ]] && ! is_known_model "$model" && [[ ! "$model" =~ ^- ]]; then
    account="$model"
    # 1) Switch account directly (no eval)
    if ! "$CCM" switch-account "$account"; then
        echo "❌ Failed to switch account: $account" >&2
        exit 1
    fi
    # Show current account summary (non-fatal if it fails)
    "$CCM" current-account || true
    # 2) Optionally set default model environment (Claude Sonnet)
    eval "$("$CCM" claude)"
else
    # Configure environment for this process using repo-local ccm
    if [[ "$model" == "open" ]]; then
        eval "$("$CCM" open "$open_provider")"
    else
        # 处理区域参数（第二个参数）- 仅当未从冒号语法解析时
        if [[ -z "$region_arg" ]] && [[ "${1:-}" =~ ^(global|china|cn)$ ]]; then
            region_arg="$1"
            shift || true
        fi

        # 设置默认区域
        case "$model" in
            ali|alibaba|kimi|kimi2|glm|glm4|glm4.6|glm4.7|minimax|mm)
                if [[ -z "$region_arg" ]]; then
                    region_arg="china"
                fi
                ;;
            seed|doubao)
                # seed 使用 variant 参数，不是 region
                if [[ -z "$model_variant" ]] && [[ "${1:-}" =~ ^(doubao|glm|glm4|glm4.7|deepseek|ds|kimi|kimi2)$ ]]; then
                    model_variant="$1"
                    shift || true
                fi
                ;;
        esac

        # 调用 ccm 传递参数
        if [[ "$model" == "seed" || "$model" == "doubao" ]]; then
            # seed 使用第二个参数作为 variant
            if [[ -n "$model_variant" ]]; then
                eval "$("$CCM" "$model" "$model_variant")"
            else
                eval "$("$CCM" "$model")"
            fi
        elif [[ -n "$model_variant" ]]; then
            # 新语法: provider:variant [region]
            if [[ -n "$region_arg" ]]; then
                eval "$("$CCM" "$model" "$model_variant" "$region_arg")"
            else
                eval "$("$CCM" "$model" "$model_variant")"
            fi
        elif [[ -n "$region_arg" ]]; then
            # 旧语法: provider [region]
            eval "$("$CCM" "$model" "$region_arg")"
        else
            eval "$("$CCM" "$model")"
        fi
    fi
fi

# Remaining args are passed through to `claude`
claude_args=("$@")

# Friendly status
echo ""
echo "🚀 Launching Claude Code..."
echo "   Model: ${ANTHROPIC_MODEL:-'(unset)'}"
echo "   Base URL: ${ANTHROPIC_BASE_URL:-'Default (Anthropic)'}"

# Ensure `claude` is available
if ! command -v claude >/dev/null 2>&1; then
    echo "❌ 'claude' CLI not found. Install it first: npm install -g @anthropic-ai/claude-code" >&2
    exit 127
fi

# Exec into Claude Code with the configured environment
# Helper: check if args already contain --dangerously-skip-permissions
has_dsp_flag() {
    for arg in "${claude_args[@]}"; do
        [[ "$arg" == "--dangerously-skip-permissions" ]] && return 0
    done
    return 1
}

# Default skip permissions (can be disabled via CCM_SKIP_PERMISSIONS=0)
SKIP_PERMS="${CCM_SKIP_PERMISSIONS:-1}"

if [[ ${#claude_args[@]} -eq 0 ]]; then
    if [[ "$SKIP_PERMS" == "1" ]]; then
        exec claude --dangerously-skip-permissions
    else
        exec claude
    fi
elif has_dsp_flag; then
    exec claude "${claude_args[@]}"
else
    if [[ "$SKIP_PERMS" == "1" ]]; then
        exec claude --dangerously-skip-permissions "${claude_args[@]}"
    else
        exec claude "${claude_args[@]}"
    fi
fi
