# CCM 配置文件示例
# 复制此文件到 ~/.ccm_config 并填入你的 API Keys
#
# 配置优先级: 环境变量 > ~/.ccm_config > 内置默认值
#
# 格式: KEY=VALUE (Bash 格式，无需引号)

# =============================================================================
# API Keys
# =============================================================================

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# Kimi (月之暗面)
KIMI_API_KEY=sk-your-kimi-key
KIMI_MODEL=kimi-k2.5

# GLM (智谱 AI)
GLM_API_KEY=sk-your-glm-key
GLM_MODEL=glm-5

# MiniMax
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_MODEL=minimax-m2.5

# StepFun (阶跃星辰)
STEPFUN_API_KEY=sk-your-stepfun-key
STEPFUN_MODEL=step-2-16k

# =============================================================================
# 阿里云 Coding Plan (统一 API Key，多模型变体)
# =============================================================================
#
# 阿里云 Coding Plan 使用统一的 QWEN_API_KEY，支持 4 种模型变体:
#
#   命令                      | 模型
#   --------------------------|------------------
#   ccm ali qwen              | qwen3.5-plus
#   ccm ali kimi              | kimi-k2.5
#   ccm ali glm               | glm-5
#   ccm ali minimax           | minimax-m2.5
#
# 变体在命令行指定，不是在配置文件中配置。

QWEN_API_KEY=sk-your-qwen-key

# (可选) 覆盖默认模型
# QWEN_MODEL=qwen3.5-plus

# =============================================================================
# Seed / 豆包 (字节跳动) - 多模型变体
# =============================================================================
#
# Seed 支持多种模型变体:
#
#   命令              | 模型
#   ------------------|------------------
#   ccm seed          | ark-code-latest (默认)
#   ccm seed doubao   | ark-code-latest
#   ccm seed glm      | glm-5
#   ccm seed deepseek | deepseek-chat
#   ccm seed kimi     | kimi-k2.5

ARK_API_KEY=sk-your-ark-key
ARK_MODEL=ark-code-latest

# =============================================================================
# Claude (官方 Anthropic)
# =============================================================================
# 留空使用官方端点，或填入自定义端点

# CLAUDE_API_KEY=sk-ant-your-key

# =============================================================================
# OpenRouter (聚合网关)
# =============================================================================
#
# OpenRouter 支持多种模型:
#
#   命令                  | 模型
#   ----------------------|---------------------------
#   ccm open claude       | anthropic/claude-sonnet-4.5
#   ccm open kimi         | moonshotai/kimi-k2.5
#   ccm open deepseek     | deepseek/deepseek-chat
#   ccm open glm          | zhipu/glm-5
#   ccm open stepfun      | stepfun/step-2-16k

OPENROUTER_API_KEY=sk-or-your-key

# =============================================================================
# 区域特定模型覆盖 (可选)
# =============================================================================
#
# 格式: <PROVIDER>_MODEL_<REGION>=model-name
#
# 示例: 为 Kimi 国内版指定不同模型
# KIMI_MODEL_CHINA=kimi-k2.5
# KIMI_MODEL_GLOBAL=kimi-k2.5

# =============================================================================
# Claude 模型覆盖 (可选)
# =============================================================================
# 用于指定 Claude Code 使用的具体模型版本

# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# OPUS_MODEL=claude-opus-4-6
# HAIKU_MODEL=claude-haiku-4-5-20251001
